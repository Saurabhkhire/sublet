modules = ["nodejs-20", "web", "postgresql-16"]
[agent]
expertMode = true
stack = "BEST_EFFORT_FALLBACK"

[nix]
channel = "stable-25_05"

[workflows]
runButton = "Project"

[[workflows.workflow]]
name = "Project"
mode = "parallel"
author = "agent"

[[workflows.workflow.tasks]]
task = "workflow.run"
args = "Start application"

[[workflows.workflow]]
name = "Start application"
author = "agent"

[[workflows.workflow.tasks]]
task = "shell.exec"
args = "bash start.sh"
waitForPort = 5000

[workflows.workflow.metadata]
outputType = "webview"

[[ports]]
localPort = 4000
externalPort = 3000

[[ports]]
localPort = 5000
externalPort = 80

[[ports]]
localPort = 5001
externalPort = 3001

[deployment]
deploymentTarget = "autoscale"
run = ["node", "--disable-warning=ExperimentalWarning", "backend/src/index.js"]
build = ["bash", "-c", "npm --prefix frontend install && npm --prefix frontend run build && npm --prefix backend install"]

[userenv]

[userenv.shared]
JWT_SECRET = "0512ee1ff1ccd697f5a129655c2c7ad616a8af36bfec325e72e6d9bd4d7aea1dc855a17d6a8ec80021ebfcb588f2abc9"
