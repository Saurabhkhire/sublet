# Copy to .env and fill in.

# Server
PORT=4000
JWT_SECRET=change-me-in-production

# Admin account (seeded on first boot). Configurable here.
ADMIN_EMAIL=admin123
ADMIN_PASSWORD=admin123

# Database
# Leave DATABASE_URL empty to use the local SQLite database (backend/data/app.db).
# Set DATABASE_URL to a Neon/Postgres connection string when deployed, e.g.:
# DATABASE_URL=postgres://user:pass@ep-xxx.neon.tech/dbname?sslmode=require
DATABASE_URL=

# OpenAI (used for team-matching "what they plan to build" similarity).
# Leave OPENAI_API_KEY empty to use the built-in deterministic fallback (works fully offline).
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4o-mini
